# AI Pricing Platform - 环境变量模板
# 复制为 .env 后按需修改

# ===== 乐园基础信息 =====
PARK_NAME=示例乐园
PARK_CAPACITY=40000
OPTIMAL_LOAD=0.75
PARK_CITY=上海

# ===== 票价边界 (嵌套字段使用双下划线) =====
PRICING__MIN_PRICE=80
PRICING__MAX_PRICE=599
PRICING__BASE_PRICE=299
PRICING__MAX_DAILY_CHANGE=0.30

# ===== 天气阈值 =====
WEATHER__RAIN_THRESHOLD_MM=5.0
WEATHER__HEAT_THRESHOLD_C=35.0
WEATHER__COLD_THRESHOLD_C=5.0

# ===== 节假日系数 =====
HOLIDAY__HOLIDAY_MARKUP=1.25
HOLIDAY__WEEKEND_MARKUP=1.10
HOLIDAY__GOLDEN_WEEK_MARKUP=1.40

# ===== 预警阈值 =====
ALERT_LOAD_RATE_HIGH=0.90
ALERT_LOAD_RATE_LOW=0.30
ALERT_REVENUE_DROP=-0.15
ALERT_COMPETITOR_CUT=-0.10

# ===== 外部API =====
WEATHER_PROVIDER=qweather
# QWEATHER_API_KEY=your_key_here
# OPENWEATHER_API_KEY=your_key_here

# ===== 性能配置 =====
FEATURE_CACHE_TTL_SECONDS=3600
API_TIMEOUT_SECONDS=30
THREADPOOL_MAX_WORKERS=8

# ===== 运行环境 =====
ENV=dev
LOG_LEVEL=INFO
